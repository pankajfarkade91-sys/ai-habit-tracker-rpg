# Application
NEXT_PUBLIC_APP_NAME="Habit Tracker RPG"
NEXT_PUBLIC_APP_DESCRIPTION="AI-powered habit tracker with RPG gamification"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/habit_tracker_rpg"
DATABASE_URL_SHADOW="postgresql://user:password@localhost:5432/habit_tracker_rpg_shadow"

# Redis
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# Authentication (Better Auth)
BETTER_AUTH_SECRET="your-secret-key-here-min-32-chars-generated-with-openssl"
BETTER_AUTH_URL="http://localhost:3000/api/auth"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# AI / Gemini API (Server-only)
GEMINI_API_KEY="your-gemini-api-key"

# Email Service (Optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="noreply@habittracker.com"

# Stripe (Optional for premium features)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Monitoring & Error Tracking
SENTRY_AUTH_TOKEN="your-sentry-auth-token"
NEXT_PUBLIC_SENTRY_DSN="your-sentry-dsn"
SENTRY_ORG="your-org"
SENTRY_PROJECT="your-project"

# Analytics
NEXT_PUBLIC_POSTHOG_KEY="your-posthog-key"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# Feature Flags
NEXT_PUBLIC_ENABLE_AI_COACH="true"
NEXT_PUBLIC_ENABLE_LEADERBOARDS="false"
NEXT_PUBLIC_ENABLE_SOCIAL="false"
NEXT_PUBLIC_ENABLE_PREMIUM="false"
NEXT_PUBLIC_ENABLE_PWA="true"

# API Configuration
API_RATE_LIMIT_REQUESTS="100"
API_RATE_LIMIT_WINDOW_MS="900000"
API_TIMEOUT_MS="30000"

# Logging
LOG_LEVEL="info"
NEXT_PUBLIC_DEBUG="false"
